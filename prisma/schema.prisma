generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id               String              @id @default(uuid())
  name             String
  location         String
  industry         String
  sponsorshipScore Float               @default(0)
  createdAt        DateTime            @default(now())
  reports          ApplicationReport[]
}

model User {
  id        String              @id @default(uuid())
  email     String              @unique
  password  String
  createdAt DateTime            @default(now())
  reports   ApplicationReport[]
}

model ApplicationReport {
  id                String   @id @default(uuid())
  companyId         String
  userId            String?
  role              String
  outcome           Outcome
  rejectedDueToVisa Boolean  @default(false)
  createdAt         DateTime @default(now())
  company           Company  @relation(fields: [companyId], references: [id])
  user              User?    @relation(fields: [userId], references: [id])
}

enum Outcome {
  hired
  rejected
  no_response
}